{
  "name": "dash-rawkey-signer",
  "version": "0.2.0",
  "description": "Sign Dash Platform state transitions as an identity using a raw private key, with no hierarchical-deterministic wallet seed.",
  "author": "Hilawe Semunegus",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "dash",
    "dash-platform",
    "identity",
    "raw-key",
    "signing",
    "recovery"
  ],
  "dependencies": {
    "@dashevo/dashcore-lib": "^0.22.0",
    "@dashevo/wasm-dpp": "4.0.0"
  },
  "peerDependencies": {
    "dash": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "dash": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "dash": "^7.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hilawe/dash-rawkey-signer.git"
  },
  "bugs": {
    "url": "https://github.com/hilawe/dash-rawkey-signer/issues"
  },
  "homepage": "https://github.com/hilawe/dash-rawkey-signer#readme"
}
